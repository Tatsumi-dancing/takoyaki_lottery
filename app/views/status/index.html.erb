<div class="status-screen">
  <header>
    <h1>🐙 TAKOYAKI STATUS</h1>
    <p>番号が表示されたら受取口までお越しください</p>
  </header>

  <main class="status-board">
    <section class="status-column waiting">
      <h2>お待ち番号</h2>

      <div class="number-grid">
        <% @waiting_orders.each do |order| %>
          <div class="order-card">
            <span>No.</span><%= order.number %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="status-column ready">
      <h2>受取可能</h2>

      <div class="number-grid">
        <% @ready_orders.each do |order| %>
          <div class="order-card ready-card">
            <span>No.</span><%= order.number %>
          </div>
        <% end %>
      </div>
    </section>
  </main>
</div>

<script>
  setTimeout(() => {
    location.reload();
  }, 3000);
</script>